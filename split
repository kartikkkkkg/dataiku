import dataiku
import pandas as pd
from io import BytesIO

# Load datasets
report = dataiku.Dataset("report_clean").get_dataframe()
hc_data = dataiku.Dataset("HC_Data_Clean").get_dataframe()
nj_data = dataiku.Dataset("New_Joiners_Clean").get_dataframe()
lv_data = dataiku.Dataset("Leavers_Clean").get_dataframe()
jr_data = dataiku.Dataset("JR_Clean").get_dataframe()
fg_data = dataiku.Dataset("Fieldglass_Clean").get_dataframe()
tf_data = dataiku.Dataset("Transfers_Clean").get_dataframe()

# Managed folder
folder = dataiku.Folder("mt_domain_output")  # ⚠️ if this fails, use folder ID

# Get MT domains
mt_list = report["MT Domain"].dropna().unique()

for mt in mt_list:

    # Filter per MT
    df = report[report["MT Domain"] == mt]
    df1 = hc_data[hc_data["MT Domain"] == mt]
    df2 = nj_data[nj_data["MT Domain"] == mt]
    df3 = lv_data[lv_data["MT Domain"] == mt]
    df4 = jr_data[jr_data["MT Domain"] == mt]
    df5 = fg_data[fg_data["MT Domain"] == mt]
    df6 = tf_data[tf_data["MT Domain"] == mt]

    # Clean filename
    safe_mt = str(mt).replace("/", "_").replace(" ", "_")

    # Create Excel in memory
    stream = BytesIO()

    with pd.ExcelWriter(stream, engine="openpyxl") as writer:
        df.to_excel(writer, index=False, sheet_name="Report")
        df1.to_excel(writer, index=False, sheet_name="HC Data")
        df2.to_excel(writer, index=False, sheet_name="New Joiners")
        df3.to_excel(writer, index=False, sheet_name="Leavers")
        df4.to_excel(writer, index=False, sheet_name="JR")
        df5.to_excel(writer, index=False, sheet_name="Fieldglass")
        df6.to_excel(writer, index=False, sheet_name="Transfers")

    stream.seek(0)

    # Save file
    with folder.get_writer(f"{safe_mt}.xlsx") as f:
        f.write(stream.read())
