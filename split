import dataiku
import pandas as pd

folder = dataiku.Folder("Reporttt")

# Read datasets
report = dataiku.Dataset("report_clean").get_dataframe()
hc = dataiku.Dataset("HC_Data_Clean").get_dataframe()
nj = dataiku.Dataset("New_Joiners_Clean").get_dataframe()
lv = dataiku.Dataset("Leavers_Clean").get_dataframe()
jr = dataiku.Dataset("JR_Clean").get_dataframe()
fg = dataiku.Dataset("Fieldglass_Clean").get_dataframe()
tr = dataiku.Dataset("Transfers_Clean").get_dataframe()

# MT list
mts = hc["MT Domain"].dropna().unique()
skip = ["OPS WRB", "OPS CIB", "FCSO"]
mts = [m for m in mts if m not in skip]

for mt in mts:

    filename = f"{mt}.xlsx"

    # 👉 THIS IS THE FIX
    with folder.get_writer(filename) as writer:

        with pd.ExcelWriter(writer, engine='openpyxl') as excel_writer:

            report[report["MT Domain"] == mt].to_excel(excel_writer, "Report", index=False)
            hc[hc["MT Domain"] == mt].to_excel(excel_writer, "HC_Data", index=False)
            nj[nj["MT Domain"] == mt].to_excel(excel_writer, "New_Joiners", index=False)
            lv[lv["MT Domain"] == mt].to_excel(excel_writer, "Leavers", index=False)
            jr[jr["MT Domain"] == mt].to_excel(excel_writer, "JR", index=False)
            fg[fg["MT Domain"] == mt].to_excel(excel_writer, "Fieldglass", index=False)

            tr_filtered = tr[
                (tr["MT Domain(To)"] == mt) |
                (tr["MT Domain (actual)"] == mt)
            ]

            tr_filtered.to_excel(excel_writer, "Transfers", index=False)

print("Done")
