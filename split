import dataiku
import pandas as pd

# Load datasets
report = dataiku.Dataset("report_clean").get_dataframe()
hc = dataiku.Dataset("HC_Data_Clean").get_dataframe()
joiners = dataiku.Dataset("New_Joiners_Clean").get_dataframe()
leavers = dataiku.Dataset("Leavers_Clean").get_dataframe()
transfers = dataiku.Dataset("Transfers_Clean").get_dataframe()

folder = dataiku.Folder("mt_domain_output")

def normalize(series):
    return series.astype(str).str.strip().str.upper()

# Get MT list
mts = normalize(hc["MT Domain"]).dropna().unique()

for mt in mts:

    safe_mt = str(mt).replace(" ", "_").replace("/", "_")

    # Apply same filtering logic as your local code
    r = report[normalize(report["MT Domain"]) == mt].copy()
    h = hc[normalize(hc["MT Domain"]) == mt].copy()
    j = joiners[normalize(joiners["MT Domain"]) == mt].copy()
    l = leavers[normalize(leavers["MT Domain"]) == mt].copy()

    cond1 = normalize(transfers["MT Domain(To)"]) == mt
    cond2 = normalize(transfers["MT Domain (actual)"]) == mt
    t = transfers[cond1 | cond2].copy()

    # Add sheet names (VERY IMPORTANT)
    r["Sheet"] = "Report"
    h["Sheet"] = "HC Data"
    j["Sheet"] = "New Joiners"
    l["Sheet"] = "Leavers"
    t["Sheet"] = "Transfers"

    final_df = pd.concat([r, h, j, l, t], ignore_index=True)

    folder.upload_stream(
        f"{safe_mt}.csv",
        final_df.to_csv(index=False).encode("utf-8")
    )
