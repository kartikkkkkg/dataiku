import dataiku
import pandas as pd

# Load datasets
report = dataiku.Dataset("report_clean").get_dataframe()
hc = dataiku.Dataset("HC_Data_Clean").get_dataframe()
joiners = dataiku.Dataset("New_Joiners_Clean").get_dataframe()
leavers = dataiku.Dataset("Leavers_Clean").get_dataframe()
transfers = dataiku.Dataset("Transfers_Clean").get_dataframe()

# Folder output
folder = dataiku.Folder("mt_domain_output")

# Normalize helper
def normalize(series):
    return series.astype(str).str.strip().str.upper()

# Get MT Domains
mt_list = normalize(report["MT Domain"]).dropna().unique()

for mt in mt_list:

    safe_mt = str(mt).replace(" ", "_").replace("/", "_")

    # Filter datasets
    r = report[normalize(report["MT Domain"]) == mt]
    h = hc[normalize(hc["MT Domain"]) == mt]
    j = joiners[normalize(joiners["MT Domain"]) == mt]
    l = leavers[normalize(leavers["MT Domain"]) == mt]

    cond1 = normalize(transfers["MT Domain(To)"]) == mt
    cond2 = normalize(transfers["MT Domain (actual)"]) == mt
    t = transfers[cond1 | cond2]

    # 🔥 Write Excel in temp
    file_path = f"/tmp/{safe_mt}.xlsx"

    writer = pd.ExcelWriter(file_path, engine="xlsxwriter")

    r.to_excel(writer, sheet_name="Report", index=False)
    h.to_excel(writer, sheet_name="HC Data", index=False)
    j.to_excel(writer, sheet_name="New Joiners", index=False)
    l.to_excel(writer, sheet_name="Leavers", index=False)
    t.to_excel(writer, sheet_name="Transfers", index=False)

    writer.close()

    # Upload to Dataiku folder
    with open(file_path, "rb") as f:
        folder.upload_stream(f"{safe_mt}.xlsx", f)
