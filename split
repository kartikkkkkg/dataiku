import dataiku
import pandas as pd

folder = dataiku.Folder("Reporttt")

# Read datasets
report = dataiku.Dataset("report_clean").get_dataframe()
hc = dataiku.Dataset("HC_Data_Clean").get_dataframe()
nj = dataiku.Dataset("New_Joiners_Clean").get_dataframe()
lv = dataiku.Dataset("Leavers_Clean").get_dataframe()
jr = dataiku.Dataset("JR_Clean").get_dataframe()
fg = dataiku.Dataset("Fieldglass_Clean").get_dataframe()
tr = dataiku.Dataset("Transfers_Clean").get_dataframe()

mts = hc["MT Domain"].dropna().unique()
skip = ["OPS WRB", "OPS CIB", "FCSO"]
mts = [m for m in mts if m not in skip]

for mt in mts:

    # Write each sheet as separate CSV
    with folder.get_writer(f"{mt}_Report.csv") as f:
        report[report["MT Domain"] == mt].to_csv(f, index=False)

    with folder.get_writer(f"{mt}_HC_Data.csv") as f:
        hc[hc["MT Domain"] == mt].to_csv(f, index=False)

    with folder.get_writer(f"{mt}_New_Joiners.csv") as f:
        nj[nj["MT Domain"] == mt].to_csv(f, index=False)

    with folder.get_writer(f"{mt}_Leavers.csv") as f:
        lv[lv["MT Domain"] == mt].to_csv(f, index=False)

    with folder.get_writer(f"{mt}_JR.csv") as f:
        jr[jr["MT Domain"] == mt].to_csv(f, index=False)

    with folder.get_writer(f"{mt}_Fieldglass.csv") as f:
        fg[fg["MT Domain"] == mt].to_csv(f, index=False)

    tr_filtered = tr[
        (tr["MT Domain(To)"] == mt) |
        (tr["MT Domain (actual)"] == mt)
    ]

    with folder.get_writer(f"{mt}_Transfers.csv") as f:
        tr_filtered.to_csv(f, index=False)

print("Done")
