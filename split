import dataiku
import pandas as pd
import os

# Load datasets
report = dataiku.Dataset("report_clean").get_dataframe()
hc = dataiku.Dataset("HC_Data_Clean").get_dataframe()
joiners = dataiku.Dataset("New_Joiners_Clean").get_dataframe()
leavers = dataiku.Dataset("Leavers_Clean").get_dataframe()
transfers = dataiku.Dataset("Transfers_Clean").get_dataframe()

# Folder
folder = dataiku.Folder("mt_domain_excels")
base_path = folder.get_path()

mt_list = report['MT Domain'].dropna().unique()

for mt in mt_list:

    safe_mt = str(mt).replace(" ", "_").replace("/", "_")

    # Filter each dataset
    r = report[report['MT Domain'] == mt].copy()
    h = hc[hc['MT Domain'] == mt].copy()
    j = joiners[joiners['MT Domain'] == mt].copy()
    l = leavers[leavers['MT Domain'] == mt].copy()
    t = transfers[transfers['MT Domain'] == mt].copy()

    # Add sheet indicator
    r['Sheet'] = 'Report'
    h['Sheet'] = 'HC_Data'
    j['Sheet'] = 'Joiners'
    l['Sheet'] = 'Leavers'
    t['Sheet'] = 'Transfers'

    # Combine all
    final_df = pd.concat([r, h, j, l, t], ignore_index=True)

    # Save single CSV per MT
    final_df.to_csv(f"{base_path}/{safe_mt}.csv", index=False)
